# Dependencies
/vendor/

# Composer lock (keep if you want reproducible installs, remove otherwise)
# composer.lock

# Exported files (generated at runtime)
/exports/pdf/*.pdf
/exports/excel/*.xlsx
/exports/excel/*.xls

# Uploaded product images (runtime data)
/uploads/products/*
!/uploads/products/.gitkeep

